# carrierpress/profiles/am-broadcast-style.profile

# Moderate AM-style local audio profile for wider voice or programme material.
# This is not the default for amateur SSB bulletin playout.
name = AM Broadcast Style
description = Moderate AM-style local audio profile
mode = am
dehummer = off
multiband = music
multiband_bands = 3
multiband2 = off
bass_eq = warm
natural_dynamics = on
low_level_boost = off
restoration_analysis = off
declipper = off
am_preset = am-wide
