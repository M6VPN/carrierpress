# carrierpress/profiles/data-clean-pass-through.profile

# Clean pass-through profile for external digital modes such as JS8, Olivia,
# and MT63. It keeps speech shaping, speech EQ, dynamics, restoration, and
# clipping repair disabled so modem-style audio is not intentionally reshaped.
name = Data Clean Pass Through
description = Clean pass-through profile for external digital mode audio
mode = neutral
dehummer = off
multiband = off
multiband2 = off
bass_eq = off
natural_dynamics = off
low_level_boost = off
restoration_analysis = off
declipper = off
am_preset = off
ssb_preset = off
